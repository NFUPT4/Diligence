{
    "$schema": "https://oxc-project.github.io/schemas/oxfmt-config.json",
    "printWidth": 100,
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "bracketSpacing": false,
    "arrowParens": "always",
    "proseWrap": "preserve",
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "overrides": [
        {
            "files": "*.js",
            "options": {
                "semi": true,
                "singleQuote": false
            }
        }
    ]
}